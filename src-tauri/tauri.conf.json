{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Terminal",
  "version": "0.1.3",
  "identifier": "com.ericterminal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Terminal",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "theme": "Dark",
        "backgroundColor": "#0F172A"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dalof41014/terminal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFOEQ1MjhBQTNGMEYwMUYKUldRZjhQQ2ppbEtOYmk2RnVQTDBTNDE5SHEvSjI4aXhjdm40SVQwR05oU0FSMWUyU05pclp6QVYK"
    }
  }
}
